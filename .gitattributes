# Normalize line endings
* text=auto

# Force LF for these file types (penting untuk Linux deployment)
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.sh   text eol=lf
*.conf text eol=lf

# Binaries
*.db   binary
*.png  binary
*.jpg  binary
*.ico  binary
