FROM node:20-alpine
WORKDIR /app

# Install dependencies
COPY server/package*.json ./
RUN npm install --production

# Copy server source
COPY server/ ./

# Database directory (will be mounted as volume)
RUN mkdir -p /data

ENV NODE_ENV=production
ENV DB_PATH=/data/maintenance.db

EXPOSE 5000
HEALTHCHECK --interval=30s --timeout=5s \
  CMD wget -qO- http://localhost:5000/api/health || exit 1

CMD ["node", "index.js"]
